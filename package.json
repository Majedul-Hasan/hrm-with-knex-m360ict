{
  "name": "m360ict",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only --ignore-watch node_modules --ignore-watch dist src/server.ts",
    "workers:dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/infrastructure/bullMQ/startWorkers.ts",
    "dev:env": "cross-env NODE_ENV=development ts-node-dev --respawn --transpile-only --ignore-watch node_modules --ignore-watch dist src/server.ts",
    "clean:queues": "ts-node -r tsconfig-paths/register --transpile-only src/infrastructure/bullMQ/queues/cleanQueues.ts",
    "clean:queues:force": "ts-node -r tsconfig-paths/register  --transpile-only src/infrastructure/bullMQ/queues/cleanQueuesForce.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "workers": "node dist/infrastructure/bullMQ/startWorkers.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "pg:start": "tsx scripts/start-postgres.ts",
    "db:create": "tsx scripts/create-db.ts",
    "knex:migrate": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/knex/bin/cli.js --knexfile src/infrastructure/persistence/knex/knexfile.ts migrate:latest",
    "knex:rollback": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/knex/bin/cli.js --knexfile src/infrastructure/persistence/knex/knexfile.ts migrate:rollback",
    "knex:make": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/knex/bin/cli.js --knexfile src/infrastructure/persistence/knex/knexfile.ts migrate:make",
    "knex:seed": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/knex/bin/cli.js --knexfile src/infrastructure/persistence/knex/knexfile.ts seed:run",
    "knex:seed:make": "node -r ts-node/register -r tsconfig-paths/register ./node_modules/knex/bin/cli.js --knexfile src/infrastructure/persistence/knex/knexfile.ts seed:make",
    "lint": "eslint \"src/**/*.{ts,js}\"",
    "lint:fix": "eslint \"src/**/*.{ts,js}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bullmq": "^5.79.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "http-status": "^2.1.0",
    "joi": "^18.2.3",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.3.0",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "eslint": "^10.6.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.4",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.9.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}